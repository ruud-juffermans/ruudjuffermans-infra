# Shared Postgres credentials. Copy to .env on the VPS and fill with real values.
#
# POSTGRES_* is the superuser — used for admin and backups only.
# Each app connects with its OWN least-privilege role below; that password also
# goes into the matching app's DATABASE_URL, e.g.
#   postgresql://ruudjuffermans_app:<password>@db:5432/ruudjuffermans
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
RUUDJUFFERMANS_DB_PASSWORD=change-me-strong-password
HABITMAXXING_DB_PASSWORD=change-me-strong-password
