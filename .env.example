# Shared Postgres credentials. Copy to .env on the VPS and fill with real values.
#
# POSTGRES_* is the superuser — used for admin and backups only.
# Each app connects with its OWN least-privilege role below; that password also
# goes into the matching app's DATABASE_URL, e.g.
#   postgresql://ruudjuffermans_app:<password>@db:5432/ruudjuffermans
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
RUUDJUFFERMANS_DB_PASSWORD=change-me-strong-password
HABITMAXXING_DB_PASSWORD=change-me-strong-password

# ─── Central admin app ───────────────────────────────────────────────────────
# The single password you log in with. Empty disables login (fail closed).
ADMIN_PASSWORD=change-me-strong-password
# Secret used to sign the admin session cookie. openssl rand -hex 32
ADMIN_COOKIE_SECRET=change-me-random-hex
# Login session lifetime in hours (optional; default 12).
ADMIN_SESSION_TTL_HOURS=12
# Browser origin the admin client is served from (credentialed CORS).
ADMIN_CORS_ORIGIN=https://panel.ruudjuffermans.nl

# Shared service token: the admin app sends this to each app's admin API. This
# value MUST be identical here AND in ruudjuffermans.nl/.env AND habitmaxxing/.env.
# Generate with: openssl rand -hex 32
ADMIN_SERVICE_TOKEN=change-me-random-hex

# Internal URLs of each app's server on dokploy-network. Defaults assume service
# names "habitmaxxing-server" / "ruudjuffermans-server"; override to match the
# actual Dokploy-assigned names if they differ.
HABITMAXXING_API_URL=http://habitmaxxing-server:4000
RUUDJUFFERMANS_API_URL=http://ruudjuffermans-server:4000
